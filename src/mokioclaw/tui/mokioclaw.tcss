Screen {
    background: #0f0e0d;
    color: #d8d1c7;
    padding: 0 1;
}

Header {
    dock: top;
    background: #0f0e0d;
    color: #d8d1c7;
    border-bottom: solid #d8704a;
}

Footer {
    dock: bottom;
    background: #0f0e0d;
    color: #807973;
    border-top: solid #3a3430;
}

#shell {
    height: 1fr;
    padding: 0 0 1 0;
}

#conversation-zone {
    width: 1fr;
    min-width: 0;
    margin-right: 1;
}

#sidebar-zone {
    width: 36;
    min-width: 28;
    max-width: 42;
}

#conversation-title,
#sidebar-title {
    color: #a35f49;
    text-style: bold;
    padding: 0 1;
    margin-bottom: 1;
}

#chat-scroll {
    height: 1fr;
    border: round #d8704a;
    background: #151311;
    padding: 1;
}

#welcome-card {
    width: 100%;
    height: 22;
    margin-bottom: 1;
    border: round #d8704a;
    background: #12100f;
}

#welcome-left {
    width: 52;
    min-width: 46;
    align: center top;
    padding: 1 1;
    border-right: solid #3a3430;
}

#welcome-right {
    width: 1fr;
    padding: 1 2;
}

#logo-mark {
    content-align: center top;
    height: 10;
    width: 48;
    margin-bottom: 1;
}

#welcome-title {
    color: #f1e7dc;
    text-style: bold;
    content-align: center middle;
    margin-top: 1;
}

#welcome-meta {
    color: #8b8580;
    content-align: center middle;
    margin-top: 1;
}

.welcome-section-title {
    color: #a35f49;
    text-style: bold;
    margin-bottom: 0;
}

.welcome-line {
    color: #c9c1b8;
    margin-bottom: 1;
}

.welcome-line.muted {
    color: #7a736d;
}

#command-cheatsheet {
    color: #d8d1c7;
    margin-bottom: 1;
}

.chat-card {
    width: 100%;
    height: auto;
    margin-bottom: 1;
    padding: 0 1 1 1;
    border: round #3a3430;
    background: #181614;
}

.chat-card .chat-kicker {
    color: #9f978f;
    text-style: bold;
    padding: 0 0 1 0;
}

.chat-card .chat-plain,
.chat-card .chat-markdown {
    color: #e0d8ce;
}

.chat-card.user {
    border: round #d8704a;
}

.chat-card.user .chat-kicker {
    color: #d8704a;
}

.chat-card.assistant {
    border: round #5a524c;
}

.chat-card.assistant .chat-kicker {
    color: #f1e7dc;
}

.chat-card.system {
    border: round #d8704a 55%;
    background: #151311;
}

.chat-card.thinking {
    border: round #d8704a 70%;
    background: #201812;
}

.chat-card.thinking .chat-kicker,
.chat-card.thinking .chat-markdown {
    color: #d8704a;
}

.chat-card.error {
    border: round #d86255 80%;
    background: #211311;
}

#composer-shell {
    height: auto;
    margin-top: 1;
    padding: 0 1 1 1;
    border: solid #3a3430;
    background: #151311;
}

#composer-shell.busy {
    border: solid #d8704a;
    background: #201812;
}

#composer-help {
    color: #807973;
    height: auto;
    padding: 1 0 0 0;
}

#composer-row {
    height: auto;
    min-height: 1;
    max-height: 5;
    margin-top: 1;
    padding: 0;
    border-top: solid #3a3430;
    align: left top;
}

#composer-prefix {
    width: 3;
    color: #d8704a;
    text-style: bold;
    padding: 0 0 0 1;
}

#chat-input {
    width: 1fr;
    height: 1;
    min-height: 1;
    max-height: 5;
    border: none;
    background: transparent;
    color: #e0d8ce;
    padding: 0;
}

#chat-input:focus {
    background: transparent;
}

#chat-input:disabled {
    color: #807973;
}

.side-panel {
    margin-bottom: 1;
    padding: 1;
    border: round #5a524c;
    background: #151311;
    height: 1fr;
}

.panel-title {
    color: #d8704a;
    text-style: bold;
    padding: 0 0 1 0;
}

.panel-scroll {
    height: 1fr;
}

.verify-panel {
    height: auto;
}

.hidden {
    display: none;
}

.empty-panel-message {
    color: #807973;
    padding: 1 0;
}

.approval-panel {
    border: round #d86255 80%;
    background: #211311;
    height: auto;
}

#approval-text {
    color: #e89282;
}

#verification-text {
    color: #e89282;
}
